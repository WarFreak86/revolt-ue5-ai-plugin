{
  "name": "revolt-editor-bridge-mcp-server",
  "version": "0.1.0",
  "description": "Offline-first MCP server for the local Revolt Unreal Editor bridge.",
  "type": "module",
  "private": true,
  "bin": {
    "revolt-editor-bridge-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test:bridge": "node dist/test-bridge.js",
    "package": "powershell -NoProfile -ExecutionPolicy Bypass -File ../scripts/package/Package-McpServer.ps1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.3"
  }
}
